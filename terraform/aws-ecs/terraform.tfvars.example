# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in your values.

aws_region    = "us-east-1"
environment   = "prod"

# Networking
vpc_cidr              = "10.0.0.0/16"
availability_zones    = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs   = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs  = ["10.0.10.0/24", "10.0.11.0/24", "10.0.12.0/24"]

# TLS (optional — leave empty for HTTP-only)
acm_certificate_arn = ""
domain_name         = ""

# RDS
rds_instance_class    = "db.t4g.medium"
rds_allocated_storage = 20
rds_multi_az          = false

# DynamoDB
dynamodb_billing_mode = "PAY_PER_REQUEST"

# ECS Task Sizing
api_cpu            = 512
api_memory         = 1024
api_desired_count  = 2

worker_cpu            = 1024
worker_memory         = 2048
worker_desired_count  = 2

ui_cpu            = 512
ui_memory         = 1024
ui_desired_count  = 2

temporal_cpu    = 1024
temporal_memory = 2048

temporal_ui_cpu    = 256
temporal_ui_memory = 512

# Secrets (required)
api_bearer_token = "CHANGE_ME"

# Git provider tokens (at least one required for worker)
github_token = ""
gitlab_token = ""

# LLM access (one of these is required)
anthropic_api_key = ""
use_bedrock       = false

# Logging
log_retention_days = 30
