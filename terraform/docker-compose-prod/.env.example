# .env.example
# Copy to .env and fill in your values

# AWS
AWS_REGION=us-east-1
DYNAMODB_TABLE=reposwarm-prod-cache

# API Authentication
API_BEARER_TOKEN=your-secure-token-here

# Git Provider Tokens (at least one required)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# LLM Access (choose one)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_CODE_USE_BEDROCK=0

# Temporal (usually no changes needed)
TEMPORAL_SERVER_URL=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=investigate-task-queue
